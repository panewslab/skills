{
  "name": "@panews/agent-plugin",
  "version": "0.1.0",
  "description": "PANews Agent Toolkit for crypto news discovery, creator workflows, and PANews page reading.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/panewslab/skills.git"
  },
  "homepage": "https://github.com/panewslab/skills",
  "files": [
    "src/openclaw.ts",
    "skills",
    ".claude-plugin",
    ".codex-plugin",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "openclaw": {
    "extensions": [
      "./src/openclaw.ts"
    ],
    "compat": {
      "pluginApi": "^1.2.0"
    },
    "build": {
      "openclawVersion": "2026.3.23-2"
    }
  },
  "scripts": {
    "build": "tsdown",
    "build:panews": "tsdown --config tsdown.config.ts --filter panews",
    "build:creator": "tsdown --config tsdown.config.ts --filter panews-creator",
    "dev": "tsdown --watch"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/turndown": "^5.0.6",
    "tsdown": "^0.21.4",
    "typescript": "^5"
  },
  "dependencies": {
    "@panews/lang": "^1.1.0",
    "citty": "^0.2.1",
    "md4x": "^0.0.25",
    "turndown": "^7.2.2",
    "zod": "^4.3.6"
  }
}
